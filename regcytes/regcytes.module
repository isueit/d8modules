function _regcytes_get_group_from_request() {
  $request = \Drupal::request();

  // group_content_menu passes ?destination= or is accessed via
  // /group/{group}/content paths — check route params first.
  $route_match = \Drupal::routeMatch();
//\Drupal::messenger()->addMessage('Route name: ' . $route_match->getRouteName());
//\Drupal::messenger()->addMessage('Raw params: ' . print_r($route_match->getRawParameters()->all(), TRUE));

  $group = $route_match->getParameter('group');
  if ($group instanceof \Drupal\group\Entity\GroupInterface) {
    return $group;
  }

  // Fallback: parse 'destination' query param if needed.
  return NULL;
}
