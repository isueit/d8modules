}

/**
 * Implements hook_theme().
 */

function regcytes_theme($existing, $type, $theme, $path)
{
  return [
    'page__type__event_homepage__canonical' => [
      'template' => 'page--type--event-homepage--canonical',
      'base hook' => 'page',
    ],
    'page__type__microsite_page__canonical' => [
      'template' => 'page--type--microsite-page--canonical',
      'base hook' => 'page',
    ],
    'menu__group_menu' => [
      'template' => 'menu--group-menu',
      'base hook' => 'menu',
    ],
    'group__hero_banner' => [
      'template' => 'group--hero-banner',
      'base hook' => 'group',
    ],
    'group__agenda' => [
      'template' => 'group--agenda',
      'base hook' => 'group',
    ],
  ];
}

/**
 * Implements hook_theme_suggestions_group_alter().
 *
 * Ensures view-mode-based template suggestions are generated for group
 * entities, so templates like group--hero-banner.html.twig are selected when
 * the hero_banner view mode is rendered.
 */
/**
 * Implements hook_preprocess_menu__group_menu().
 *
 * Passes registration open/closed state to the template so the Register link
 * can be shown only when registration is active.
 */
function regcytes_preprocess_menu__group_menu(array &$variables): void {
  $variables['registration_is_open'] = FALSE;
  $variables['registration_url'] = '';

  try {
    $contexts = \Drupal::service('regcytes.path_prefix_context')
      ->getRuntimeContexts(['group']);

    if (empty($contexts['group'])) {
      return;
    }

    $group = $contexts['group']->getContextValue();
    if (!$group instanceof GroupInterface) {
      return;
    }

    // Vary per URL path so each group site gets its own cached menu.
    $variables['#cache']['contexts'][] = 'url.path';
    // Invalidate when the group entity is saved (e.g. dates change).
    $variables['#cache']['tags'] = array_merge(
      $variables['#cache']['tags'] ?? [],
      $group->getCacheTags()
    );

    $reg_field = $group->get('field_subsite_registration_deets');
    if ($reg_field->isEmpty()) {
      return;
    }

    $reg_paragraph = $reg_field->entity;
    if (!$reg_paragraph) {
      return;
    }

    $link_field = $reg_paragraph->get('field_subsite_registration_link');
    if ($link_field->isEmpty()) {
      return;
    }

    $open_date = $reg_paragraph->get('field_subsite_registration_open')->value;
    $close_date = $reg_paragraph->get('field_subsite_registration_close')->value;
    $current_date = date('Y-m-d');

    if ($open_date && $close_date && $open_date <= $current_date && $close_date >= $current_date) {
      $variables['registration_is_open'] = TRUE;
      $variables['registration_url'] = $link_field->first()->getUrl()->toString();
    }
  }
  catch (\Throwable $e) {
    // Context not available; leave defaults.
  }
}

/**
 * Implements hook_theme_suggestions_group_alter().
 */
function regcytes_theme_suggestions_group_alter(array &$suggestions, array $variables) {
  $view_mode = $variables['elements']['#view_mode'] ?? NULL;
  if (!$view_mode) {
    return;
  }
  $group = $variables['elements']['#group'] ?? NULL;
  $suggestions[] = 'group__' . $view_mode;
  if ($group instanceof GroupInterface) {
    $suggestions[] = 'group__' . $group->bundle() . '__' . $view_mode;
  }
}

