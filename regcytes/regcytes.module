/**
 * Implements hook_preprocess_html().
 *
 * Adds a 'group-site' body class on any page within a group URL prefix so
 * theme CSS can suppress the global site name in the navbar.
 */
function regcytes_preprocess_html(array &$variables): void {
  try {
    $contexts = \Drupal::service('regcytes.path_prefix_context')
      ->getRuntimeContexts(['group']);

    if (empty($contexts['group'])) {
      return;
    }

    $group = $contexts['group']->getContextValue();
    if ($group instanceof GroupInterface) {
      $variables['attributes']['class'][] = 'group-site';
    }
  }
  catch (\Throwable $e) {
    // Context unavailable — do nothing.
  }
}

/**
 * Implements hook_preprocess_page().
 *
 * Passes hide_default_footer and subsite_contact to page templates based on
 * the current group resolved via the regcytes path-prefix context.
 */
function regcytes_preprocess_page(array &$variables): void {
  $variables['hide_default_footer'] = FALSE;
  $variables['show_site_contact_info'] = FALSE;
  $variables['subsite_contact'] = NULL;

  try {
    $contexts = \Drupal::service('regcytes.path_prefix_context')
      ->getRuntimeContexts(['group']);

    if (empty($contexts['group'])) {
      return;
    }

    $group = $contexts['group']->getContextValue();
    if (!$group instanceof GroupInterface) {
      return;
    }

    if ($group->hasField('field_hide_default_footer')
      && !$group->get('field_hide_default_footer')->isEmpty()
      && (bool) $group->get('field_hide_default_footer')->value) {
      $variables['hide_default_footer'] = TRUE;
    }

    if ($group->bundle() === 'isu_event_website') {
      $variables['show_site_contact_info'] = TRUE;

      if ($group->hasField('field_subsite_contact')
        && !$group->get('field_subsite_contact')->isEmpty()) {
        $variables['subsite_contact'] = $group->field_subsite_contact->entity;
      }

    }
  }
  catch (\Throwable $e) {
    // Context unavailable — leave defaults.
  }
}

