/**
 * Syncs path_prefix on a group when its alias is saved.
 */
function regcytes_sync_group_path_prefix(\Drupal\path_alias\Entity\PathAlias $path_alias)
{
  $system_path = $path_alias->getPath();

  // Check if this alias belongs to a group: /group/{id}
  if (!preg_match('#^/group/(\d+)$#', $system_path, $matches)) {
    return;
  }

  $group_id = $matches[1];
  $group = \Drupal\group\Entity\Group::load($group_id);

  if (!$group) {
    return;
  }

  $new_alias = $path_alias->getAlias();
  $current_prefix = $group->get('group_context_path_prefix')->value;

  if ($current_prefix !== $new_alias) {
    $group->set('group_context_path_prefix', $new_alias);
    \Drupal::entityTypeManager()->getStorage('group')->save($group);
  }
}

/**
 * Implements hook_form_alter().
 *
 * Require the URL Aliases in groups, and try to expand the tab containing this field
 */
function regcytes_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id)
{
  //\Drupal::messenger()->addMessage('Form ID: ' . $form_id);
  // Target group add/edit forms. Optionally restrict to a specific group type:
  // e.g. 'group_my_group_type_add_form' / 'group_my_group_type_edit_form'
  if (preg_match('/^group_.*_(add|edit)_form$/', $form_id)) {

    $form['#after_build'][] = 'regcytes_group_color_after_build';
    $form['#after_build'][] = 'regcytes_group_form_after_build';

    // The path alias widget lives here.
    if (isset($form['path']['widget'][0]['alias'])) {
      $form['path']['widget'][0]['alias']['#required'] = TRUE;

      // Add a custom validate handler.
      $form['#validate'][] = 'regcytes_group_alias_required_validate';
    }

    if (isset($form['path'])) {
      $form['path']['#open'] = TRUE;
    }

    if (isset($form['path']['widget'][0]['alias'])) {
      $form['path']['widget'][0]['alias']['#required'] = TRUE;
      $form['#validate'][] = 'regcytes_group_alias_required_validate';
    }
  }

    //if ($form_id === 'menu_link_content_menu_link_content_form'
    //  || $form_id === 'menu_link_content_memu_link_content_edit_form') {
    if (strpos($form_id, 'menu_link_content_') === 0) {

    $group = _regcytes_get_group_from_request();
    if ($group) {

    $url = \Drupal\Core\Url::fromRoute('regcytes.group_node_autocomplete', ['group' => $group->id()])
      ->toString();

    $form['#attached']['library'][] = 'regcytes/group_autocomplete';
    $form['#attached']['drupalSettings']['regcytes']['groupAutocompleteUrl'] = $url;
    }
    }

    // Target group entity add/edit forms only.
  if (!preg_match('/^group_.+_(add|edit)_form$/', $form_id)) {
    return;
  }
 
  // Only attach if the color fields are present on this group type.
  if (!isset($form['field_color_enabled'])) {
    return;
  }
 
  $defaults = regcytes_color_defaults();
  $css_map  = regcytes_color_css_map();
 
  $color_fields = [];
  foreach ($css_map as $field => $css_var) {
    $color_fields[] = [
      'fieldName'     => $field,
      'inputSelector' => '[name="' . $field . '[0][value]"]',
      'cssVar'        => $css_var,
      'default'       => $defaults[$field],
      'isButton'      => str_starts_with($field, 'field_color_btn_'),
    ];
  }
 
  $form['#attached']['library'][] = 'regcytes/group_color_picker';
  $form['#attached']['drupalSettings']['regcytesGroupColors'] = [
    'fields'          => $color_fields,
    'enabledSelector' => '[name="field_color_enabled[value]"]',
    'webaim_api_base' => 'https://webaim.org/resources/contrastchecker/',
  ];
/*
  // Targets group content menu link add/edit forms.
  if (in_array($form_id, ['menu_link_content_menu_link_content_form'])) {

    $group = _regcytes_get_group_from_request();
    echo "I am here";
    if ($group) {
      echo "Group is " . $group->id();

      // Store group id for the autocomplete route.
      $form['link']['widget'][0]['uri']['#autocomplete_route_name'] =
        'regcytes.group_node_autocomplete';
      $form['link']['widget'][0]['uri']['#autocomplete_route_parameters'] = [
        'group' => $group->id(),
      ];
    }
  }
*/
}

function regcytes_field_widget_single_element_form_alter(
  array &$element,
  \Drupal\Core\Form\FormStateInterface $form_state,
  array $context
) {
    $field_definition = $context['items']->getFieldDefinition();

    if ($field_definition->getName() !== 'link') {
      return;
    }
    if ($field_definition->getTargetEntityTypeId() !== 'menu_link_content') {
      return;
    }

    $group = _regcytes_get_group_from_request();
    if (!$group) {
      return;
    }

    // Keep this in case it ever starts working, but the real
    // override is now done via JS attached in hook_form_alter.
    $element['uri']['#autocomplete_route_name'] = 'regcytes.group_node_autocomplete';
    $element['uri']['#autocomplete_route_parameters'] = [
      'group' => $group->id(),
    ];

}



/**
 * #after_build callback — moves all field descriptions above the input.
 */
function regcytes_group_form_after_build(array $form, \Drupal\Core\Form\FormStateInterface $form_state): array {
  _regcytes_description_before($form);
  return $form;
}

/**
 * Recursively sets #description_display to 'before' on all form elements.
 */
function _regcytes_description_before(array &$element): void {
  foreach (array_keys($element) as $key) {
    if ($key[0] === '#' || !is_array($element[$key])) {
      continue;
    }
    if (isset($element[$key]['#description'])) {
      $element[$key]['#description_display'] = 'before';
    }
    _regcytes_description_before($element[$key]);
  }
}

/**
 * Validation handler — ensures the alias field is not empty.
 */
function regcytes_group_alias_required_validate(&$form, \Drupal\Core\Form\FormStateInterface $form_state)
{
  $path_values = $form_state->getValue(['path', 0]);
  $alias = trim($path_values['alias'] ?? '');

  if (empty($alias)) {
    $form_state->setError(
      $form['path']['widget'][0]['alias'],
      t('The URL alias field is required.')
    );
  }
}

