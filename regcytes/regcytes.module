function regcytes_preprocess_config_pages__homepage(&$variables)
{
  //$group = regcytes_get_group();
  $group = _regcytes_get_group_from_request();
  if ($group) {
    $variables['group'] = $group->getFields();
    $variables['deleteme'] = 'Should delete me';
  }
}

