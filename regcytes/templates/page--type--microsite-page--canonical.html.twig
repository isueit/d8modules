{#
/**
 * @file
 * Theme override to display a single page.
 *
 * The doctype, html, head and body tags are not in this template. Instead they
 * can be found in the html.html.twig template in this directory.
 *
 * Available variables:
 *
 * General utility variables:
 * - base_path: The base URL path of the Drupal installation. Will usually be
 *   "/" unless you have installed Drupal in a sub-directory.
 * - is_front: A flag indicating if the current page is the front page.
 * - logged_in: A flag indicating if the user is registered and signed in.
 * - is_admin: A flag indicating if the user has permission to access
 *   administration pages.
 *
 * Site identity:
 * - front_page: The URL of the front page. Use this instead of base_path when
 *   linking to the front page. This includes the language domain or prefix.
 *
 * Page content (in order of occurrence in the default page.html.twig):
 * - messages: Status and error messages. Should be displayed prominently.
 * - node: Fully loaded node, if there is an automatically-loaded node
 *   associated with the page and the node ID is the second argument in the
 *   page's path (e.g. node/12345 and node/12345/revisions, but not
 *   comment/reply/12345).
 *
 * Regions:
 *   parts/site-navbar.html.twig
 *   - page.header_first: First half of headery, typically for site branding.
 *   - page.header_second: Second half of header, typically for search and
 *     site links.
 *
 *   parts/menu-navbar.html.twig
 *   - page.menu_navbar: Primary site navigation
 *
 *   page.html.twig
 *   - page.post_nav: Full width region preceding content.
 *   - page.highlighted: Items for the highlighted content region.
 *   - page.breadcrumb: Items for the breadcrumb region.
 *   - page.content: The main content of the current page.
 *   - page.sidebar_first: Items for the first sidebar.
 *   - page.sidebar_second: Items for the second sidebar.
 *
 *   footer.html.twig
 *   - page.footer_first: Items for first footer region
 *   - page.footer_second: Items for second footer region
 *   - page.footer_third: Items for third footer region
 *   - page.footer_fourth: Items for fourth footer region
 *   - page.sign_off: For small end-of-page items.
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
#}

<div class="isu-page-wrap regcytes-microsite">

	{# ISU Navbar is suppressed entirely for custom-themed microsites #}
	{% if isu_navbar and not custom_theme %}
		{% include '@iastate_theme/parts/isu-navbar.html.twig' %}
	{% endif %}

	{% if custom_theme %}
		<header class="regcytes-custom-header" role="banner" aria-label="Site header">
			<div class="container">
				<div class="regcytes-custom-header__inner">

					<div class="regcytes-custom-header__brand">
						{% if subsite_logo_url %}
							<img src="{{ subsite_logo_url }}" alt="{{ subsite_logo_alt }}" class="regcytes-custom-header__logo">
						{% endif %}
						<div class="regcytes-custom-header__info">
							{% if subsite_dates_formatted or subsite_location %}
								<p class="regcytes-custom-header__meta">
									{{- subsite_dates_formatted -}}
									{%- if subsite_dates_formatted and subsite_location %} &nbsp;·&nbsp; {% endif -%}
									{{- subsite_location -}}
								</p>
							{% endif %}
							{% if subsite_group_label %}
								<p class="regcytes-custom-header__title">{{ subsite_group_label }}</p>
							{% endif %}
						</div>
					</div>

					<div class="regcytes-custom-header__actions">
						{% if subsite_registration_url %}
							<a href="{{ subsite_registration_url }}" class="btn regcytes-register-btn">
								Register Now <i class="fa-solid fa-angle-right"></i>
							</a>
						{% endif %}
						<button class="navbar-toggler isu-menu-navbar_toggler" type="button" data-toggle="collapse" id="isu-menu-navbar_toggler" aria-expanded="false" aria-label="Toggle navigation">
							<span class="isu-menu-navbar_toggler-label sr-only">Menu</span>
							<div class="navbar-toggler-icon isu-menu-navbar_toggler-icon">
								<span class="mm-line-1"></span>
								<span class="mm-line-2"></span>
								<span class="mm-line-3"></span>
							</div>
						</button>
					</div>

				</div>
			</div>
		</header>
	{% else %}
		{# site-navbar.html.twig contains branded ISU header #}
		{% include '@iastate_theme/parts/site-navbar.html.twig' %}
	{% endif %}

	{# menu-navbar.html.twig contains the main menu #}
	{% include '@iastate_theme/parts/menu-navbar.html.twig' %}

	<main class="isu-main" role="main">

		<a id="main-content" tabindex="-1"></a>
		{% if page.post_nav %}
			{{ page.post_nav }}
		{% endif %}

		{{ page.breadcrumbs }}

		<div class="row">

			{% if page.sidebar_first|render and page.sidebar_second|render %}
				{% set content_classes = 'col-lg-6' %}
				{% set sidebar_classes = 'col-lg-3' %}
			{% elseif page.sidebar_first|render or page.sidebar_second|render %}
				{% set content_classes = 'col-lg-9' %}
				{% set sidebar_classes = 'col-lg-3' %}
			{% else %}
				{% set content_classes = 'col-lg-12' %}
			{% endif %}

			{% if page.sidebar_first|render %}
				<div class="isu-page-column isu-sidebar isu-sidebar-first {{sidebar_classes}}">
					<aside role="complementary">
						{{ page.sidebar_first }}
					</aside>
				</div>
			{% endif %}
			{% if page.content|render %}
				<div class="isu-page-column isu-content-column {{ content_classes }}">
					{{ page.content|without('iastate_theme_page_title') }}
				</div>
			{% endif %}

			{% if page.sidebar_second|render %}
				<div class="isu-page-column isu-sidebar isu-sidebar-second {{sidebar_classes}}">
					<aside role="complementary">
						{{ page.sidebar_second }}
					</aside>
				</div>
			{% endif %}

		</div>

	</main>

	{% if show_site_contact_info and not (custom_theme and hide_default_footer) %}
		<section class="site-contact-info{% if custom_theme %} site-contact-info--custom-theme{% endif %}" aria-label="Contact information">
			<div class="site-contact-info__inner">

				{% if subsite_contact %}
					<div class="site-contact-info__column">

						{% if subsite_contact.field_microsite_contact_heading.value %}
							<p class="site-contact-info__label">{{ subsite_contact.field_microsite_contact_heading.value }}</p>
						{% endif %}

						{% if subsite_contact.field_microsite_contact_name.value %}
							<p class="site-contact-info__name">{{ subsite_contact.field_microsite_contact_name.value }}</p>
						{% endif %}

						{% if subsite_contact.field_microsite_contact_title.value %}
							<p class="site-contact-info__meta">{{ subsite_contact.field_microsite_contact_title.value }}</p>
						{% endif %}

						{% if subsite_contact.field_microsite_contact_org.value %}
							<p class="site-contact-info__meta">{{ subsite_contact.field_microsite_contact_org.value }}</p>
						{% endif %}

						{% set addr = subsite_contact.field_microsite_contact_address[0] %}
						{% if addr and addr.address_line1 %}
							<p class="site-contact-info__meta">
								{{- addr.address_line1 -}}
								{%- if addr.address_line2 %}<br>{{ addr.address_line2 }}{% endif -%}
								{%- if addr.locality or addr.administrative_area or addr.postal_code %}
									<br>{{ addr.locality }}{% if addr.locality and addr.administrative_area %}, {% endif %}{{ addr.administrative_area }} {{ addr.postal_code }}
								{%- endif %}
							</p>
						{% endif %}

						{% if subsite_contact.field_microsite_contact_phone.value %}
							<p class="site-contact-info__link">
								<a href="tel:{{ subsite_contact.field_microsite_contact_phone.value|replace({' ': '', '(': '', ')': '', '-': ''}) }}">{{ subsite_contact.field_microsite_contact_phone.value }}</a>
							</p>
						{% endif %}

						{% if subsite_contact.field_microsite_contact_email.value %}
							<p class="site-contact-info__link">
								<a href="mailto:{{ subsite_contact.field_microsite_contact_email.value }}">{{ subsite_contact.field_microsite_contact_email.value }}</a>
							</p>
						{% endif %}

						{% if subsite_contact.field_microsite_contact_website.uri %}
							<p class="site-contact-info__link">
								<a href="{{ subsite_contact.field_microsite_contact_website.uri }}" rel="noopener noreferrer">
									{{- subsite_contact.field_microsite_contact_website.title ?: subsite_contact.field_microsite_contact_website.uri -}}
								</a>
							</p>
						{% endif %}

					</div>
				{% endif %}

				<div class="site-contact-info__column {% if subsite_contact %}site-contact-info__column--divided{% endif %}">
					<p class="site-contact-info__label">Registration Questions</p>
					<p class="site-contact-info__name">Registration Services</p>
					<p class="site-contact-info__meta">Iowa State University Extension and Outreach</p>
					<p class="site-contact-info__meta">2121 State Ave, Ames, IA 50011</p>
					<p class="site-contact-info__link"><a href="tel:5152946222">515-294-6222</a></p>
					<p class="site-contact-info__link"><a href="mailto:registrations@iastate.edu">registrations@iastate.edu</a></p>
				</div>

			</div>
		</section>
	{% endif %}

	{% if not hide_default_footer and not custom_theme %}
		{% include '@iastate_theme/parts/footer.html.twig' %}
	{% endif %}

</div>
