---
import porkbotIconOne from '../assets/PorkChatBot-01.png';
import porkbotIconTwo from '../assets/PorkChatBot-02.png';
import popupIslandClientUrl from './porkbot/popup-island.js?url';

const typingGif = '/typing.gif';

const popupConfig = {
  assistantName: 'Porkbot',
  islandTitle: 'Porkbot Chat Island',
  subtitle: 'Switch between compact widget mode and immersive full-page mode.',
  widgetTitle: 'Quick Support Widget',
  widgetBody: 'Open the floating assistant for fast answers while staying in your workflow.',
  fullPageTitle: 'Full Page Assistant',
  fullPageBody: 'Use the full-size layout for deep troubleshooting and long-form conversations.',
  openButtonLabel: 'Open Porkbot chat',
  openButtonIcon: porkbotIconTwo.src,
  tokenEndpoint:
    'https://default0347d89a01744dd3adeb3339c89c35.f5.environment.api.powerplatform.com/powervirtualagents/botsbyschema/copilots_header_0e4cf/directline/token?api-version=2022-03-01-preview',
  backgroundImage: '',
  openByDefault: false,
  defaultMode: 'widget',
  conversationStarters: [
    { icon: 'chat', label: 'Hello', send: 'Hello' },
    { icon: 'spark', label: 'Sick Leave Policy', send: "What's the sick leave policy?" },
    { icon: 'spark', label: 'Identity Theft Prevention', send: 'Do we have a theft prevention program?' },
    { icon: 'spark', label: 'Contact ISD', send: 'Contact ISD' },
    { icon: 'bulb', label: 'Report Incorrect Response', send: 'I want to report an incorrect response' }
  ],
  styleOptions: {
    accent: '#0078D4',
    autoScrollSnapOnPage: true,
    autoScrollSnapOnPageOffset: 0,
    avatarBorderRadius: '7%',
    avatarSize: 56,
    backgroundColor: '#eef2f7',
    botAvatarBackgroundColor: '#ffffff00',
    botAvatarImage: porkbotIconOne.src,
    botAvatarInitials: 'B',
    bubbleAttachmentMaxWidth: 520,
    bubbleAttachmentMinWidth: 240,
    bubbleBackground: '#ffffff',
    bubbleBorderColor: '#dde3ec',
    bubbleBorderRadius: 26,
    bubbleBorderStyle: 'solid',
    bubbleBorderWidth: 1,
    bubbleFromUserBackground: '#fde8ec',
    bubbleFromUserBorderColor: '#f4cfd7',
    bubbleFromUserBorderRadius: 26,
    bubbleFromUserBorderStyle: 'solid',
    bubbleFromUserBorderWidth: 1,
    bubbleFromUserNubOffset: 0,
    bubbleFromUserNubSize: 0,
    bubbleFromUserTextColor: '#1f2937',
    bubbleImageHeight: 10,
    bubbleImageMaxHeight: 240,
    bubbleImageMinHeight: 240,
    bubbleMessageMaxWidth: 520,
    bubbleMessageMinWidth: 140,
    bubbleMinHeight: 46,
    bubbleNubOffset: 0,
    bubbleTextColor: '#1f2937',
    emojiSet: true,
    fontSizeSmall: '72%',
    hideUploadButton: false,
    messageActivityWordBreak: 'break-word',
    monospaceFont: 'Consolas',
    paddingRegular: 12,
    paddingWide: 12,
    primaryFont: '"Source Sans 3", "Segoe UI", sans-serif',
    sendBoxButtonColor: '#C8102E',
    sendBoxButtonColorOnHover: '#A50E26',
    sendBoxBackground: '#eef2f7',
    sendBoxTextColor: '#111827',
    sendBoxBorderTop: 'solid 1px #D5DCE8',
    sendBoxButtonShadeBorderRadius: 40,
    sendBoxButtonShadeColorOnHover: '',
    sendBoxHeight: 60,
    sendBoxPlaceholderColor: '#4B5563',
    showAvatarInGroup: 'status',
    spinnerAnimationHeight: 16,
    spinnerAnimationPadding: 12,
    spinnerAnimationWidth: 16,
    subtleColor: '#374151',
    suggestedActionBackgroundColor: '#C8102E',
    suggestedActionBackgroundColorOnHover: '#A50E26',
    suggestedActionBorderColor: '',
    suggestedActionBorderRadius: 999,
    suggestedActionBorderWidth: 1,
    suggestedActionLayout: 'flow',
    suggestedActionTextColor: '#FFFFFF',
    typingAnimationBackgroundImage: `url('${typingGif}')`,
    typingAnimationDuration: 5000,
    typingAnimationHeight: 20,
    typingAnimationWidth: 64,
    userAvatarBackgroundColor: '#111827'
  }
};

const popupConfigJson = JSON.stringify(popupConfig);
---

<section class="porkbot-island" data-porkbot-root data-porkbot-config={popupConfigJson}></section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap');

  .porkbot-island {
    --isu-cardinal: #c8102e;
    --isu-cardinal-deep: #8e0a20;
    --isu-gold: #f1be48;
    --ink-900: #111827;
    --ink-700: #334155;
    --line: #d9e0ea;
    --panel-bg: #f8fbff;
    --panel-shadow: 0 22px 50px rgba(17, 24, 39, 0.16);
    position: relative;
    min-height: 820px;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.14);
    background: radial-gradient(circle at 14% 16%, #fff6da 0%, rgba(255, 246, 218, 0.2) 30%, transparent 58%),
      radial-gradient(circle at 88% 10%, #ffd8df 0%, rgba(255, 216, 223, 0.24) 36%, transparent 62%),
      linear-gradient(160deg, #f6f8fc 0%, #edf2f9 52%, #e4ebf5 100%);
    box-shadow: 0 26px 54px rgba(15, 23, 42, 0.16);
  }

  .porkbot-island :global(*) {
    box-sizing: border-box;
  }

  .porkbot-island :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .porkbot-island :global(.pb-shell) {
    position: relative;
    z-index: 2;
    min-height: 820px;
    padding: 22px;
    font-family: 'Source Sans 3', 'Segoe UI', sans-serif;
    color: var(--ink-900);
  }

  .porkbot-island :global(.pb-orb) {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(2px);
    opacity: 0.75;
    z-index: 1;
  }

  .porkbot-island :global(.pb-orb--one) {
    width: 190px;
    height: 190px;
    top: 14px;
    right: 34px;
    background: radial-gradient(circle at 28% 30%, #ffffff 0%, #ffd5de 52%, rgba(255, 141, 164, 0.2) 100%);
  }

  .porkbot-island :global(.pb-orb--two) {
    width: 230px;
    height: 230px;
    bottom: -42px;
    left: -34px;
    background: radial-gradient(circle at 68% 40%, #fff5c9 0%, rgba(241, 190, 72, 0.28) 56%, rgba(255, 240, 196, 0.06) 100%);
  }

  .porkbot-island :global(.pb-modebar) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: end;
    padding: 18px 20px;
    border-radius: 16px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(8px);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
  }

  .porkbot-island :global(.pb-kicker) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7f1d1d;
  }

  .porkbot-island :global(.pb-kicker::before) {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--isu-cardinal);
  }

  .porkbot-island :global(.pb-title) {
    margin: 6px 0 2px;
    font-family: 'Outfit', 'Avenir Next', sans-serif;
    font-size: clamp(26px, 3.6vw, 40px);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .porkbot-island :global(.pb-title span) {
    color: var(--isu-cardinal);
  }

  .porkbot-island :global(.pb-subtitle) {
    margin: 0;
    max-width: 68ch;
    font-size: 18px;
    color: #475569;
    line-height: 1.5;
  }

  .porkbot-island :global(.pb-tab-wrap) {
    display: grid;
    gap: 8px;
    justify-items: end;
  }

  .porkbot-island :global(.pb-tablist) {
    display: inline-grid;
    grid-auto-flow: column;
    gap: 6px;
    padding: 6px;
    border-radius: 999px;
    background: #f3f4f6;
    border: 1px solid rgba(148, 163, 184, 0.35);
  }

  .porkbot-island :global(.pb-tab) {
    min-width: 120px;
    min-height: 44px;
    padding: 10px 18px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: #334155;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .porkbot-island :global(.pb-tab[aria-selected='true']) {
    color: #ffffff;
    background: linear-gradient(135deg, #d91b3b 0%, #b6102a 100%);
    box-shadow: 0 8px 18px rgba(200, 16, 46, 0.35);
  }

  .porkbot-island :global(.pb-tab:hover) {
    transform: translateY(-1px);
  }

  .porkbot-island :global(.pb-tab:focus-visible),
  .porkbot-island :global(.pb-action:focus-visible),
  .porkbot-island :global(.pb-starter:focus-visible),
  .porkbot-island :global(.pb-widget-launch:focus-visible) {
    outline: 3px solid rgba(200, 16, 46, 0.35);
    outline-offset: 2px;
  }

  .porkbot-island :global(.pb-hint) {
    margin: 0;
    font-size: 14px;
    color: #64748b;
  }

  .porkbot-island :global(.pb-panels) {
    margin-top: 18px;
  }

  .porkbot-island :global(.pb-panel) {
    min-height: 700px;
  }

  .porkbot-island :global(.pb-panel[hidden]) {
    display: none;
  }

  .porkbot-island :global(.pb-widget-stage) {
    position: relative;
    min-height: 700px;
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.9) 0%, rgba(245, 249, 255, 0.85) 50%, rgba(240, 245, 252, 0.92) 100%);
    box-shadow: 0 18px 35px rgba(15, 23, 42, 0.1);
    overflow: hidden;
    padding: 24px;
  }

  .porkbot-island :global(.pb-widget-deco) {
    position: absolute;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(203, 213, 225, 0.5);
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
  }

  .porkbot-island :global(.pb-widget-deco--analytics) {
    width: 230px;
    height: 120px;
    top: 26px;
    left: 26px;
  }

  .porkbot-island :global(.pb-widget-deco--feed) {
    width: 200px;
    height: 150px;
    bottom: 38px;
    left: 32px;
  }

  .porkbot-island :global(.pb-widget-copy) {
    max-width: 420px;
    padding-top: 140px;
  }

  .porkbot-island :global(.pb-widget-copy h3) {
    margin: 0 0 10px;
    font-family: 'Outfit', 'Avenir Next', sans-serif;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.03;
    letter-spacing: -0.03em;
    color: #0f172a;
  }

  .porkbot-island :global(.pb-widget-copy p) {
    margin: 0;
    font-size: 17px;
    line-height: 1.5;
    color: #475569;
  }

  .porkbot-island :global(.pb-widget-launch) {
    position: absolute;
    right: 24px;
    bottom: 24px;
    min-width: 220px;
    min-height: 58px;
    padding: 10px 16px 10px 12px;
    border: none;
    border-radius: 999px;
    background: linear-gradient(145deg, #d01939 0%, #b01029 100%);
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    box-shadow: 0 16px 24px rgba(200, 16, 46, 0.34);
    transition: transform 180ms ease, box-shadow 180ms ease;
    z-index: 20;
  }

  .porkbot-island :global(.pb-widget-launch:hover) {
    transform: translateY(-2px);
    box-shadow: 0 18px 28px rgba(200, 16, 46, 0.42);
  }

  .porkbot-island :global(.pb-widget-launch img) {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .porkbot-island :global(.pb-widget-popup) {
    position: absolute;
    right: 24px;
    bottom: 96px;
    width: min(470px, calc(100% - 32px));
    height: 590px;
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: #ffffff;
    box-shadow: var(--panel-shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform-origin: bottom right;
    transform: scale(0.96) translateY(14px);
    opacity: 0;
    pointer-events: none;
    transition: transform 220ms ease, opacity 220ms ease;
    z-index: 40;
  }

  .porkbot-island :global(.pb-widget-popup.is-open) {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .porkbot-island :global(.pb-chat-header) {
    min-height: 60px;
    padding: 8px 8px 8px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(145deg, #ce1737 0%, #a90e26 100%);
    color: #ffffff;
  }

  .porkbot-island :global(.pb-chat-title) {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    font-family: 'Outfit', 'Avenir Next', sans-serif;
  }

  .porkbot-island :global(.pb-chat-title :is(svg, .pb-chat-icon)) {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .porkbot-island :global(.pb-chat-title-text) {
    font-size: 18px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .porkbot-island :global(.pb-chat-actions) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .porkbot-island :global(.pb-action) {
    min-width: 44px;
    min-height: 44px;
    border: none;
    border-radius: 12px;
    background: transparent;
    color: #fff6df;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 180ms ease;
  }

  .porkbot-island :global(.pb-action:hover) {
    background: rgba(255, 255, 255, 0.16);
  }

  .porkbot-island :global(.pb-chat-intro) {
    padding: 16px;
    border-bottom: 1px solid #e2e8f0;
    background: linear-gradient(180deg, #f9fafb 0%, #f1f5f9 100%);
  }

  .porkbot-island :global(.pb-chat-intro h4) {
    margin: 0;
    font-family: 'Outfit', 'Avenir Next', sans-serif;
    font-size: 28px;
    line-height: 1.02;
    letter-spacing: -0.02em;
  }

  .porkbot-island :global(.pb-chat-intro h4 span) {
    color: var(--isu-cardinal);
    display: block;
  }

  .porkbot-island :global(.pb-chat-intro p) {
    margin: 8px 0 0;
    color: #475569;
    font-size: 15px;
    line-height: 1.4;
  }

  .porkbot-island :global(.pb-starters) {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .porkbot-island :global(.pb-starters.is-column) {
    flex-direction: column;
    align-items: stretch;
  }

  .porkbot-island :global(.pb-starter) {
    min-height: 44px;
    border: 1px solid #d7dee9;
    border-radius: 999px;
    background: #ffffff;
    color: #1f2937;
    padding: 9px 14px;
    font-size: 14px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    text-align: left;
    transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
  }

  .porkbot-island :global(.pb-starters.is-column .pb-starter) {
    border-radius: 14px;
    padding: 12px 14px;
  }

  .porkbot-island :global(.pb-starter:hover) {
    border-color: rgba(200, 16, 46, 0.45);
    background: #fff5f7;
    transform: translateY(-1px);
  }

  .porkbot-island :global(.pb-starter-icon) {
    width: 16px;
    height: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .porkbot-island :global(.pb-webchat) {
    position: relative;
    flex: 1;
    min-height: 0;
    background: #eef2f7;
  }

  .porkbot-island :global(.pb-webchat > div) {
    position: relative;
    z-index: 2;
  }

  .porkbot-island :global(.webchat-overlay) {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.78);
  }

  .porkbot-island :global(.pb-full-layout) {
    min-height: 700px;
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(8px);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.1);
    display: grid;
    grid-template-columns: minmax(240px, 290px) minmax(0, 1fr);
    overflow: hidden;
  }

  .porkbot-island :global(.pb-full-sidebar) {
    padding: 22px;
    border-right: 1px solid #e2e8f0;
    background: linear-gradient(160deg, #f8fafc 0%, #f1f5f9 100%);
  }

  .porkbot-island :global(.pb-full-sidebar h3) {
    margin: 0;
    font-family: 'Outfit', 'Avenir Next', sans-serif;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #0f172a;
  }

  .porkbot-island :global(.pb-full-sidebar h3 span) {
    color: var(--isu-cardinal);
    display: block;
    margin-top: 2px;
  }

  .porkbot-island :global(.pb-full-sidebar p) {
    margin: 10px 0 0;
    color: #475569;
    font-size: 16px;
    line-height: 1.5;
  }

  .porkbot-island :global(.pb-full-chat) {
    min-height: 700px;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .porkbot-island :global(.pb-full-chat .pb-chat-header) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .porkbot-island :global(.pb-full-chat .pb-webchat) {
    min-height: 0;
  }

  .porkbot-island :global(.pb-widget-popup .webchat__basic-transcript__content),
  .porkbot-island :global(.pb-full-chat .webchat__basic-transcript__content) {
    white-space: pre-wrap !important;
    word-break: break-word !important;
  }

  .porkbot-island :global(.pb-widget-popup .webchat__bubble__content),
  .porkbot-island :global(.pb-full-chat .webchat__bubble__content) {
    padding: 0 !important;
  }

  .porkbot-island :global(.pb-widget-popup .webchat__bubble),
  .porkbot-island :global(.pb-full-chat .webchat__bubble) {
    max-width: 96% !important;
    margin: 0 !important;
  }

  .porkbot-island :global(.pb-widget-popup .webchat__basic-transcript__content ul),
  .porkbot-island :global(.pb-widget-popup .webchat__basic-transcript__content ol),
  .porkbot-island :global(.pb-full-chat .webchat__basic-transcript__content ul),
  .porkbot-island :global(.pb-full-chat .webchat__basic-transcript__content ol) {
    padding-left: 24px !important;
    margin: 8px 0 !important;
  }

  .porkbot-island :global(.pb-widget-popup .webchat__basic-transcript__content li),
  .porkbot-island :global(.pb-full-chat .webchat__basic-transcript__content li) {
    margin: 4px 0 !important;
    padding-left: 2px !important;
  }

  .porkbot-island :global(.pb-widget-popup .webchat__typingIndicator),
  .porkbot-island :global(.pb-widget-popup .webchat__typing-indicator),
  .porkbot-island :global(.pb-widget-popup .webchat__typing-indicator__content),
  .porkbot-island :global(.pb-widget-popup .webchat__typing),
  .porkbot-island :global(.pb-full-chat .webchat__typingIndicator),
  .porkbot-island :global(.pb-full-chat .webchat__typing-indicator),
  .porkbot-island :global(.pb-full-chat .webchat__typing-indicator__content),
  .porkbot-island :global(.pb-full-chat .webchat__typing) {
    background-image: url('/typing.gif') !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    background-size: contain !important;
    min-width: 64px !important;
    min-height: 20px !important;
  }

  @media (max-width: 1120px) {
    .porkbot-island {
      min-height: 860px;
    }

    .porkbot-island :global(.pb-modebar) {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .porkbot-island :global(.pb-tab-wrap) {
      justify-items: start;
    }

    .porkbot-island :global(.pb-full-layout) {
      grid-template-columns: 1fr;
      min-height: 740px;
    }

    .porkbot-island :global(.pb-full-sidebar) {
      border-right: none;
      border-bottom: 1px solid #e2e8f0;
    }
  }

  @media (max-width: 768px) {
    .porkbot-island {
      border-radius: 14px;
      min-height: 880px;
    }

    .porkbot-island :global(.pb-shell) {
      padding: 12px;
      min-height: 880px;
    }

    .porkbot-island :global(.pb-modebar) {
      padding: 14px;
      border-radius: 12px;
    }

    .porkbot-island :global(.pb-subtitle) {
      font-size: 16px;
    }

    .porkbot-island :global(.pb-tablist) {
      width: 100%;
      grid-template-columns: 1fr 1fr;
    }

    .porkbot-island :global(.pb-tab) {
      width: 100%;
      min-width: 0;
    }

    .porkbot-island :global(.pb-widget-stage) {
      min-height: 740px;
      padding: 16px;
    }

    .porkbot-island :global(.pb-widget-deco) {
      display: none;
    }

    .porkbot-island :global(.pb-widget-copy) {
      padding-top: 0;
      max-width: 100%;
    }

    .porkbot-island :global(.pb-widget-popup) {
      left: 10px;
      right: 10px;
      width: auto;
      bottom: 86px;
      height: 610px;
      border-radius: 14px;
    }

